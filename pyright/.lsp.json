{
  "python": {
    "command": "pyright-langserver",
    "args": ["--stdio"],
    "extensionToLanguage": {
      ".py": "python",
      ".pyi": "python"
    },
    "initializationOptions": {
      "diagnosticMode": "openFilesOnly"
    },
    "settings": {
      "python": {
        "analysis": {
          "autoSearchPaths": true,
          "useLibraryCodeForTypes": true,
          "diagnosticMode": "openFilesOnly",
          "typeCheckingMode": "standard",
          "autoImportCompletions": true
        }
      }
    }
  }
}
