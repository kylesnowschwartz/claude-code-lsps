{
  "bash": {
    "command": "bash-language-server",
    "args": ["start"],
    "extensionToLanguage": {
      ".sh": "shellscript",
      ".bash": "shellscript",
      ".zsh": "shellscript",
      ".ksh": "shellscript"
    },
    "settings": {
      "bashIde": {
        "enableSourceErrorDiagnostics": true,
        "includeAllWorkspaceSymbols": true,
        "backgroundAnalysisMaxFiles": 500,
        "shellcheckPath": "shellcheck"
      }
    }
  }
}
